@page
@model IndexModel
@using GhAdoE2eDemo.Web
@{
    ViewData["Title"] = HomeContent.Title;
}

<section aria-labelledby="hero-heading">
    <h1 id="hero-heading">@HomeContent.Title</h1>
    <p>@HomeContent.HeroMessage</p>
</section>

<section aria-labelledby="whatsnew-heading">
    <h2 id="whatsnew-heading">What's New</h2>
    <ul>
        @foreach (var item in HomeContent.Highlights)
        {
            <li>@item</li>
        }
    </ul>
</section>

<section aria-labelledby="devsecops-heading">
    <h2 id="devsecops-heading">DevSecOps</h2>
    <p>
        Read the latest news about
        <a href="/DevSecOps-4821">GitHub Advanced Security</a>.
    </p>
</section>
