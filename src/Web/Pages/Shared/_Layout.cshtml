<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Parts Unlimited</title>
    <style>
        :root {
            color-scheme: light;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            margin: 0;
        }

        .site-header,
        main,
        footer {
            padding: 1rem;
        }

        .site-header {
            align-items: center;
            border-bottom: 1px solid #d0d7de;
            display: flex;
            gap: 1rem;
            justify-content: space-between;
        }

        .site-brand,
        .site-nav-links a,
        footer a {
            color: #0969da;
            text-decoration: none;
        }

        .site-brand {
            font-size: 1.125rem;
            font-weight: 700;
        }

        .site-nav {
            display: flex;
        }

        .nav-toggle {
            background: transparent;
            border: 1px solid #8c959f;
            border-radius: 0.375rem;
            display: none;
            padding: 0.5rem;
        }

        .nav-toggle:focus-visible,
        .site-nav-links a:focus-visible,
        .site-brand:focus-visible,
        footer a:focus-visible {
            outline: 2px solid #0969da;
            outline-offset: 2px;
        }

        .nav-toggle-icon {
            display: grid;
            gap: 0.25rem;
        }

        .nav-toggle-icon span {
            background: #24292f;
            display: block;
            height: 2px;
            width: 1.25rem;
        }

        .site-nav-links {
            display: flex;
            gap: 1rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        footer {
            border-top: 1px solid #d0d7de;
        }

        @@media (max-width: 640px) {
            .site-header {
                align-items: flex-start;
                flex-wrap: wrap;
            }

            .nav-toggle {
                display: inline-flex;
            }

            .site-nav {
                flex-basis: 100%;
            }

            .site-nav-links {
                flex-direction: column;
                gap: 0.75rem;
                max-height: 0;
                opacity: 0;
                overflow: hidden;
                transition: max-height 0.2s ease, opacity 0.2s ease;
                visibility: hidden;
            }

            .site-nav-links.is-open {
                max-height: 80vh;
                opacity: 1;
                overflow-y: auto;
                visibility: visible;
            }
        }
    </style>
</head>
<body>
    <header class="site-header">
        <a class="site-brand" href="/">Parts Unlimited</a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-navigation" aria-label="Toggle navigation">
            <span class="nav-toggle-icon" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
            </span>
        </button>
        <nav class="site-nav" aria-label="Primary">
            <ul id="primary-navigation" class="site-nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/privacy">Privacy</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>
    <footer>
        @* User Story: "Refresh the footer with the current year and key links" (year is dynamic). *@
        <p>&copy; @DateTime.UtcNow.Year Parts Unlimited &middot;
            <a href="/privacy">Privacy</a> &middot;
            <a href="/contact">Contact</a>
        </p>
    </footer>
    <script>
        const navToggle = document.querySelector('.nav-toggle');
        const navMenu = document.querySelector('#primary-navigation');

        if (navToggle && navMenu) {
            const closeMenu = () => {
                navMenu.classList.remove('is-open');
                navToggle.setAttribute('aria-expanded', 'false');
            };

            const toggleMenu = () => {
                const isOpen = navToggle.getAttribute('aria-expanded') === 'true';
                navMenu.classList.toggle('is-open', !isOpen);
                navToggle.setAttribute('aria-expanded', (!isOpen).toString());
            };

            navToggle.addEventListener('click', toggleMenu);

            navMenu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', closeMenu);
            });

            document.addEventListener('keydown', event => {
                if (event.key === 'Escape' && navMenu.classList.contains('is-open')) {
                    closeMenu();
                    navToggle.focus();
                }
            });
        }
    </script>
</body>
</html>
