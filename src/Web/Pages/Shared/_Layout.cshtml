<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Parts Unlimited</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container">
            <a class="brand" href="/">
                <span class="brand-mark">PU</span>
                <span>Parts Unlimited</span>
            </a>
            <nav class="site-nav" aria-label="Primary">
                <a href="/">Home</a>
                <a href="/privacy">Privacy</a>
                <a href="/contact">Contact</a>
            </nav>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer">
        @* User Story: "Refresh the footer with the current year and key links" (year is dynamic). *@
        <div class="container">
            <span>&copy; @DateTime.UtcNow.Year Parts Unlimited</span>
            <nav aria-label="Footer">
                <a href="/privacy">Privacy</a> &middot;
                <a href="/contact">Contact</a>
            </nav>
        </div>
    </footer>
</body>
</html>
